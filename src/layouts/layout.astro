---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import QuoteModal from '../components/QuoteModal.astro';

// Set KM Flooring as the default title if one isn't provided by the specific page
const { title = "KM Flooring | Premium LVT & Flooring Installation in Hull" } = Astro.props;
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    </head>
  <body class="bg-brand-light font-sans text-brand-navy antialiased flex flex-col min-h-screen">
    
    <Header />
    
    <div class="flex-grow">
      <slot /> 
    </div>

    <Footer />
    
    <QuoteModal />
    
  </body>
</html>