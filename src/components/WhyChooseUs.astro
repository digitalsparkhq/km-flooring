---
// src/components/WhyChooseUs.astro
---

<section class="relative py-24 bg-brand-navy overflow-hidden" id="about">
  
  <div class="absolute inset-0 z-0 opacity-10 pointer-events-none paving-pattern"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <div class="reveal-left">
        <h2 class="text-3xl md:text-5xl font-heading font-bold text-white mb-6">
          About <span class="text-brand-teal">KMS Removals</span>
        </h2>
        <p class="text-brand-light/90 text-lg mb-8 font-sans leading-relaxed">
          Based in Doncaster and covering the entire UK, KMS Removals brings over a decade of hands-on experience to every job. Whether you are moving down the street or across the country, our priority is providing an affordable, efficient, and stress-free service.
        </p>
        
        <ul class="space-y-4 mb-10 text-brand-light font-medium">
          <li class="flex items-center">
            <svg class="w-6 h-6 text-brand-teal mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Over 10 years of trusted, professional removal experience.
          </li>
          <li class="flex items-center">
            <svg class="w-6 h-6 text-brand-teal mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Fully insured with Public Liability and Goods in Transit coverage.
          </li>
          <li class="flex items-center">
            <svg class="w-6 h-6 text-brand-teal mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            A dedicated, hardworking team that treats your property with respect.
          </li>
        </ul>

        <div class="relative rounded-lg overflow-hidden shadow-2xl h-64 sm:h-80 w-full md:w-4/5 border-l-4 border-brand-teal">
          <img src="/images/who-we-are.jpg" alt="The KMS Removals Team" class="object-cover w-full h-full opacity-90 hover:opacity-100 transition-opacity duration-500" />
          <div class="absolute inset-0 bg-brand-navy/10 mix-blend-overlay"></div>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 reveal-right">
        
        <div class="bg-white/5 border border-white/10 backdrop-blur-sm rounded-xl p-8 text-center transform transition-transform hover:-translate-y-2">
          <div class="text-brand-teal mb-4 flex justify-center">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <div class="flex justify-center items-baseline text-white font-heading font-bold text-5xl mb-2">
            <span class="stat-number" data-target="10">0</span>
            <span class="text-brand-teal ml-1">+</span>
          </div>
          <p class="text-brand-light/70 uppercase tracking-wider text-sm font-semibold">Years Experience</p>
        </div>

        <div class="bg-white/5 border border-white/10 backdrop-blur-sm rounded-xl p-8 text-center transform transition-transform hover:-translate-y-2 sm:translate-y-8">
          <div class="text-brand-teal mb-4 flex justify-center">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
          </div>
          <div class="flex justify-center items-baseline text-white font-heading font-bold text-5xl mb-2">
            <span class="stat-number" data-target="130">0</span>
            <span class="text-brand-teal ml-1">+</span>
          </div>
          <p class="text-brand-light/70 uppercase tracking-wider text-sm font-semibold">5-Star Reviews</p>
        </div>

        <div class="bg-white/5 border border-white/10 backdrop-blur-sm rounded-xl p-8 text-center transform transition-transform hover:-translate-y-2">
          <div class="text-brand-teal mb-4 flex justify-center">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"></path></svg>
          </div>
          <div class="flex justify-center items-baseline text-white font-heading font-bold text-5xl mb-2">
            <span class="stat-number" data-target="100">0</span>
            <span class="text-brand-teal ml-1">%</span>
          </div>
          <p class="text-brand-light/70 uppercase tracking-wider text-sm font-semibold">Reliability</p>
        </div>

        <div class="bg-brand-teal rounded-xl p-8 text-center flex flex-col justify-center items-center transform transition-transform hover:-translate-y-2 sm:translate-y-8 shadow-lg">
          <h3 class="text-brand-navy font-heading font-bold text-2xl mb-4">Ready to move?</h3>
          <button class="quote-trigger bg-brand-navy text-white px-6 py-3 rounded-md hover:bg-white hover:text-brand-navy transition-colors font-heading font-bold shadow-md cursor-pointer">
            Get Your Quote
          </button>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .paving-pattern {
    background-color: transparent;
    background-image: linear-gradient(335deg, rgba(255,255,255,0.03) 23px, transparent 23px),
                      linear-gradient(155deg, rgba(255,255,255,0.03) 23px, transparent 23px),
                      linear-gradient(335deg, rgba(255,255,255,0.03) 23px, transparent 23px),
                      linear-gradient(155deg, rgba(255,255,255,0.03) 23px, transparent 23px);
    background-size: 58px 58px;
    background-position: 0px 2px, 4px 35px, 29px 31px, 34px 6px;
  }

  .reveal-left {
    opacity: 0;
    transform: translateX(-40px);
    transition: all 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-right {
    opacity: 0;
    transform: translateX(40px);
    transition: all 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .is-revealed {
    opacity: 1;
    transform: translateX(0);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    
    const revealOptions = { root: null, rootMargin: '0px', threshold: 0.2 };
    const revealObserver = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          observer.unobserve(entry.target);
        }
      });
    }, revealOptions);

    document.querySelectorAll('.reveal-left, .reveal-right').forEach(el => revealObserver.observe(el));

    const stats = document.querySelectorAll('.stat-number');
    let hasAnimated = false; 

    const animateStats = () => {
      stats.forEach(stat => {
        const target = parseInt(stat.getAttribute('data-target') || '0', 10);
        const duration = 2000; 
        const frameDuration = 1000 / 60; 
        const totalFrames = Math.round(duration / frameDuration);
        const easeOutQuad = (t: number) => t * (2 - t); 

        let frame = 0;
        const counter = setInterval(() => {
          frame++;
          const progress = easeOutQuad(frame / totalFrames);
          const currentCount = Math.round(target * progress);

          if (stat.textContent !== null) {
            stat.textContent = currentCount.toString();
          }

          if (frame === totalFrames) {
            clearInterval(counter);
            if (stat.textContent !== null) {
              stat.textContent = target.toString(); 
            }
          }
        }, frameDuration);
      });
    };

    const statsObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !hasAnimated) {
          hasAnimated = true;
          animateStats();
        }
      });
    }, { threshold: 0.2 });

    const statsContainer = document.querySelector('.reveal-right');
    if (statsContainer) {
      statsObserver.observe(statsContainer);
    }

  });
</script>