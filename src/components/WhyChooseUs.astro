---
// src/components/WhyChooseUs.astro

// High-quality wood flooring image
const whyChooseUsImage = "/images/why-choose-us.jpg";
---

<section class="py-24 bg-white overflow-hidden relative" id="why-choose-us">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
      
      <div class="mb-12 lg:mb-0 reveal-left">
        <span class="text-brand-teal font-bold tracking-widest uppercase text-sm mb-3 block">Why Choose KM Flooring</span>
        <h2 class="text-3xl md:text-5xl font-heading font-black text-brand-navy mb-6 leading-tight uppercase tracking-tight">
          A Flawless Finish, <span class="text-brand-teal">Every Time.</span>
        </h2>
        <p class="text-lg text-gray-600 mb-10 font-sans font-medium leading-relaxed max-w-2xl">
          Whether you're looking for classic herringbone or sleek straight planks, we provide end-to-end flooring solutions. We handle everything from crucial subfloor preparation to the final fitting, ensuring your new floor is perfect.
        </p>

        <div class="space-y-8">
          
          <div class="flex items-start">
            <div class="flex-shrink-0 mt-1">
              <div class="flex items-center justify-center h-12 w-12 rounded-md bg-brand-navy text-brand-teal shadow-md">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
              </div>
            </div>
            <div class="ml-5">
              <h4 class="text-xl font-heading font-bold text-brand-navy">Expert Installation</h4>
              <p class="mt-2 text-gray-600 font-medium">Attention to detail is our priority. We expertly lay custom borders, feature strips, and complex patterns that transform your space.</p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="flex-shrink-0 mt-1">
              <div class="flex items-center justify-center h-12 w-12 rounded-md bg-brand-navy text-brand-teal shadow-md">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
              </div>
            </div>
            <div class="ml-5">
              <h4 class="text-xl font-heading font-bold text-brand-navy">Premium Materials</h4>
              <p class="mt-2 text-gray-600 font-medium">We supply top-tier LVT that offers the beautiful look of real wood, combined with water resistance and the strength to handle busy, pet-friendly homes.</p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="flex-shrink-0 mt-1">
              <div class="flex items-center justify-center h-12 w-12 rounded-md bg-brand-navy text-brand-teal shadow-md">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
            </div>
            <div class="ml-5">
              <h4 class="text-xl font-heading font-bold text-brand-navy">Unbeatable Value</h4>
              <p class="mt-2 text-gray-600 font-medium">High standards shouldn't mean inflated prices. We offer competitive rates and completely free, no-obligation quotes across East Yorkshire.</p>
            </div>
          </div>

        </div>
      </div>

      <div class="relative mt-10 lg:mt-0 reveal-right">
        <div class="absolute -inset-4 bg-brand-teal/20 rounded-2xl transform translate-x-4 translate-y-4"></div>
        
        <div class="relative rounded-2xl overflow-hidden shadow-2xl border-4 border-white aspect-[4/5] md:aspect-auto md:h-[600px]">
          <img 
            src={whyChooseUsImage} 
            alt="Expert LVT Flooring Installation" 
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-brand-navy/60 via-transparent to-transparent"></div>
        </div>

        <div class="absolute -bottom-6 -left-6 md:bottom-10 md:-left-10 bg-white p-6 rounded-xl shadow-xl border-t-4 border-brand-teal flex items-center gap-4 animate-float">
          <div class="bg-brand-navy text-brand-teal rounded-full p-4 flex-shrink-0">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          </div>
          <div>
            <p class="text-sm text-gray-500 font-bold uppercase tracking-wider mb-1">Guaranteed</p>
            <p class="text-2xl font-black text-brand-navy font-heading">Flawless Finish</p>
          </div>
        </div>
        
      </div>

    </div>
  </div>
</section>

<style>
  /* Scroll Reveal Animations */
  .reveal-left {
    opacity: 0;
    transform: translateX(-40px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }
  
  .reveal-right {
    opacity: 0;
    transform: translateX(40px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  .reveal-left.is-visible,
  .reveal-right.is-visible {
    opacity: 1;
    transform: translateX(0);
  }

  /* Floating animation for the badge */
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.2
    };

    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    const animatedElements = document.querySelectorAll('.reveal-left, .reveal-right');
    animatedElements.forEach((el) => observer.observe(el));
  });
</script>