---
// src/components/Hero.astro
---

<section class="relative pt-20 pb-12 md:pb-48 lg:pt-32 lg:pb-56 bg-brand-navy" id="hero-section">
  
  <div class="absolute inset-0 overflow-hidden z-0">
    <div id="bg-bottom" class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero1.jpg');"></div>
    <div id="puzzle-layer" class="absolute inset-0"></div>
    <div class="absolute inset-0 bg-brand-navy/60"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
    <div class="max-w-3xl text-white">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold tracking-tight mb-6 leading-tight">
        Affordable, Efficient & Reliable <span class="text-brand-teal">Removals</span>.
      </h1>
      <p class="text-lg sm:text-xl mb-8 text-white/95 font-sans max-w-xl font-medium">
        Your professional removal service based in Doncaster, covering the whole UK. From full house moves to single item store collections. No job too big or small!
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 mb-8">
        <button class="quote-trigger inline-flex justify-center items-center px-8 py-3.5 border border-transparent text-base font-bold rounded-md text-brand-navy bg-brand-teal hover:bg-white transition-colors font-heading shadow-md cursor-pointer">
          Get a Free Quote
        </button>
        <a href="#our-work" class="inline-flex justify-center items-center px-8 py-3.5 border-2 border-brand-teal text-base font-bold rounded-md text-brand-teal hover:bg-brand-teal hover:text-brand-navy transition-colors font-heading bg-brand-navy/30 backdrop-blur-sm">
          See Our Work
        </a>
      </div>

      <div class="flex flex-wrap gap-6 items-center text-sm font-semibold text-white mb-8 md:mb-12">
        <div class="flex items-center drop-shadow-md">
          <svg class="w-5 h-5 mr-2 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
          Over 130 5-Star Reviews
        </div>
        <div class="flex items-center drop-shadow-md">
          <svg class="w-5 h-5 mr-2 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          Fully Insured (Public Liability & Transit)
        </div>
      </div>

    </div>
  </div>

  <div class="relative mt-12 md:mt-0 md:absolute md:-bottom-16 left-0 w-full px-4 sm:px-6 lg:px-8 z-20">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
      
      <div class="reveal-hero-box bg-white rounded-lg shadow-subtle p-6 flex flex-col items-center text-center border-t-4 border-brand-teal">
        <div class="bg-brand-light p-3 rounded-full mb-4 text-brand-teal">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
        </div>
        <h3 class="font-heading font-bold text-brand-navy mb-2">Full/Half House Moves</h3>
        <p class="text-sm text-gray-600">Local or long distance. 2-3 man teams, mattress covers used, plus free dismantling and reassembly.</p>
      </div>

      <div class="reveal-hero-box bg-white rounded-lg shadow-subtle p-6 flex flex-col items-center text-center border-t-4 border-brand-teal">
        <div class="bg-brand-light p-3 rounded-full mb-4 text-brand-teal">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path></svg>
        </div>
        <h3 class="font-heading font-bold text-brand-navy mb-2">Man with a Van</h3>
        <p class="text-sm text-gray-600">Perfect for single items, sofa relocations, and store pickups from Wickes, B&Q, and more.</p>
      </div>

      <div class="reveal-hero-box bg-white rounded-lg shadow-subtle p-6 flex flex-col items-center text-center border-t-4 border-brand-teal">
        <div class="bg-brand-light p-3 rounded-full mb-4 text-brand-teal">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
        </div>
        <h3 class="font-heading font-bold text-brand-navy mb-2">Clearances & Scrap</h3>
        <p class="text-sm text-gray-600">Complete home and office clearances. We also collect any scrap metal entirely free of charge.</p>
      </div>

    </div>
  </div>
</section>

<div class="hidden md:block h-24 bg-brand-light"></div>

<style>
  /* Updated to class-based scroll reveal mechanics */
  .reveal-hero-box {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .reveal-hero-box.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // 1. Puzzle Background Logic
  const images = [
    '/images/hero1.jpg', 
    'https://images.unsplash.com/photo-1586864387967-d02ef85d93e8?q=80&w=2940&auto=format&fit=crop', 
    'https://images.unsplash.com/photo-1532996122724-e3c354a0b15b?q=80&w=2940&auto=format&fit=crop'  
  ];
  
  let currentIndex = 0;
  const puzzleLayer = document.getElementById('puzzle-layer');
  const bottomBg = document.getElementById('bg-bottom');
  
  const cols = 6;
  const rows = 4;

  function initPuzzle() {
    if(!puzzleLayer) return;
    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const tile = document.createElement('div');
        tile.className = 'absolute inset-0 bg-cover bg-center';
        tile.style.backgroundImage = `url(${images[0]})`;
        tile.style.transition = 'opacity 0.4s ease-out';
        
        const top = (r / rows) * 100;
        const bottom = 100 - ((r + 1) / rows) * 100;
        const left = (c / cols) * 100;
        const right = 100 - ((c + 1) / cols) * 100;
        
        tile.style.clipPath = `inset(${top}% ${right}% ${bottom}% ${left}%)`;
        puzzleLayer.appendChild(tile);
      }
    }
  }

  function triggerPuzzleTransition() {
    if(!puzzleLayer || !bottomBg) return;

    const nextIndex = (currentIndex + 1) % images.length;
    bottomBg.style.backgroundImage = `url(${images[nextIndex]})`;

    const tiles = Array.from(puzzleLayer.children) as HTMLElement[];
    const shuffledTiles = [...tiles].sort(() => Math.random() - 0.5);

    shuffledTiles.forEach((tile, i) => {
      setTimeout(() => {
        tile.style.opacity = '0';
      }, i * 30); 
    });

    setTimeout(() => {
      tiles.forEach(tile => {
        tile.style.transition = 'none'; 
        tile.style.backgroundImage = `url(${images[nextIndex]})`;
        tile.style.opacity = '1';
      });
      
      void puzzleLayer.offsetWidth;
      
      tiles.forEach(tile => {
        tile.style.transition = 'opacity 0.4s ease-out';
      });
      
      currentIndex = nextIndex;
    }, (tiles.length * 30) + 500);
  }

  initPuzzle();
  setInterval(triggerPuzzleTransition, 5000);

  // 2. Scroll Reveal Logic for the Floating Boxes
  document.addEventListener('DOMContentLoaded', () => {
    const heroBoxes = document.querySelectorAll('.reveal-hero-box');
    
    const heroObserver = new IntersectionObserver((entries, observer) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          // Finds the index of the box to create a staggered delay effect
          const index = Array.from(heroBoxes).indexOf(entry.target);
          setTimeout(() => {
            entry.target.classList.add('is-revealed');
          }, index * 150); // 150ms delay between each box
          
          observer.unobserve(entry.target); // Stop observing once revealed
        }
      });
    }, { threshold: 0.1 }); // Triggers when at least 10% of the box is visible

    heroBoxes.forEach(box => heroObserver.observe(box));
  });
</script>