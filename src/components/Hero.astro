---
// src/components/Hero.astro
---

<section class="relative pt-20 pb-12 md:pb-48 lg:pt-32 lg:pb-56 bg-brand-navy" id="hero-section">
  
  <div class="absolute inset-0 overflow-hidden z-0">
    <div id="bg-bottom" class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero1.jpg');"></div>
    <div id="puzzle-layer" class="absolute inset-0"></div>
    <div class="absolute inset-0 bg-brand-navy/70"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
    <div class="max-w-3xl text-white">
      
      <h1 class="animate-sweep-left text-4xl sm:text-5xl lg:text-6xl font-heading font-black tracking-tight mb-6 leading-tight">
        Premium LVT & Flooring Installation in <span class="text-brand-teal">Hull</span>.
      </h1>
      
      <p class="animate-glide-up text-lg sm:text-xl mb-8 text-white/95 font-sans max-w-xl font-medium leading-relaxed">
        Flooring supplied and fitted to a flawless standard at great prices. From classic herringbone LVT to durable safety flooring, we deliver style and strength for your home.
      </p>
      
      <div class="animate-fade-up-delayed flex flex-col sm:flex-row gap-4 mb-8">
        <button class="quote-trigger inline-flex justify-center items-center px-8 py-3.5 border border-transparent text-base font-bold rounded-md text-brand-navy bg-brand-teal hover:bg-white transition-colors font-heading shadow-md cursor-pointer">
          Get a Free Quote
        </button>
        <a href="#our-work" class="inline-flex justify-center items-center px-8 py-3.5 border-2 border-brand-teal text-base font-bold rounded-md text-brand-teal hover:bg-brand-teal hover:text-brand-navy transition-colors font-heading bg-brand-navy/30 backdrop-blur-sm">
          See Our Work
        </a>
      </div>

      <div class="animate-fade-up-delayed-2 flex flex-wrap gap-6 items-center text-sm font-semibold text-white mb-8 md:mb-12">
        <div class="flex items-center drop-shadow-md">
          <svg class="w-5 h-5 mr-2 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          Expert Supply & Fit
        </div>
        <div class="flex items-center drop-shadow-md">
          <svg class="w-5 h-5 mr-2 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          Flawless Finish Guaranteed
        </div>
      </div>

    </div>
  </div>

  <div class="relative mt-12 md:mt-0 md:absolute md:-bottom-16 left-0 w-full px-4 sm:px-6 lg:px-8 z-20">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
      
      <div class="reveal-hero-box bg-white rounded-xl shadow-subtle p-6 flex flex-col items-center text-center border-t-4 border-brand-teal">
        <div class="bg-slate-100 p-3 rounded-full mb-4 text-brand-teal">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
        </div>
        <h3 class="font-heading font-black text-brand-navy mb-2 tracking-wide">Luxury Vinyl Tile (LVT)</h3>
        <p class="text-sm text-gray-600 font-medium">Water-resistant, low maintenance, and durable. Get the stunning look of real wood with the strength to handle everyday busy homes.</p>
      </div>

      <div class="reveal-hero-box bg-white rounded-xl shadow-subtle p-6 flex flex-col items-center text-center border-t-4 border-brand-teal">
        <div class="bg-slate-100 p-3 rounded-full mb-4 text-brand-teal">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5"></path></svg>
        </div>
        <h3 class="font-heading font-black text-brand-navy mb-2 tracking-wide">Herringbone & Borders</h3>
        <p class="text-sm text-gray-600 font-medium">Add character and movement with classic herringbone patterns, contrast feature strips, and double plank borders for a sharp layout.</p>
      </div>

      <div class="reveal-hero-box bg-white rounded-xl shadow-subtle p-6 flex flex-col items-center text-center border-t-4 border-brand-teal">
        <div class="bg-slate-100 p-3 rounded-full mb-4 text-brand-teal">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
        </div>
        <h3 class="font-heading font-black text-brand-navy mb-2 tracking-wide">Safety Flooring</h3>
        <p class="text-sm text-gray-600 font-medium">Reliable, high-quality, slip-resistant flooring supplied and expertly fitted for both demanding residential and commercial spaces.</p>
      </div>

    </div>
  </div>
</section>


<style>
  /* --- NEW TEXT ENTRY ANIMATIONS --- */
  
  /* Sweep in from left */
  .animate-sweep-left {
    opacity: 0;
    animation: sweepLeft 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes sweepLeft {
    0% { opacity: 0; transform: translateX(-40px); }
    100% { opacity: 1; transform: translateX(0); }
  }

  /* Glide up from bottom */
  .animate-glide-up {
    opacity: 0;
    animation: glideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 200ms;
  }
  @keyframes glideUp {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* Staggered glide ups for buttons and features */
  .animate-fade-up-delayed {
    opacity: 0;
    animation: glideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 400ms;
  }
  .animate-fade-up-delayed-2 {
    opacity: 0;
    animation: glideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 600ms;
  }

  /* --- EXISTING SCROLL ANIMATIONS --- */
  .reveal-hero-box {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .reveal-hero-box.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // 1. Puzzle Background Logic
  const images = [
    '/images/floor8.jpg', 
    '/images/hero2.jpg', 
    '/images/hero3.jpg'  
  ];
  
  let currentIndex = 0;
  const puzzleLayer = document.getElementById('puzzle-layer');
  const bottomBg = document.getElementById('bg-bottom');
  
  const cols = 6;
  const rows = 4;

  function initPuzzle() {
    if(!puzzleLayer) return;
    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const tile = document.createElement('div');
        tile.className = 'absolute inset-0 bg-cover bg-center';
        tile.style.backgroundImage = `url(${images[0]})`;
        tile.style.transition = 'opacity 0.4s ease-out';
        
        const top = (r / rows) * 100;
        const bottom = 100 - ((r + 1) / rows) * 100;
        const left = (c / cols) * 100;
        const right = 100 - ((c + 1) / cols) * 100;
        
        tile.style.clipPath = `inset(${top}% ${right}% ${bottom}% ${left}%)`;
        puzzleLayer.appendChild(tile);
      }
    }
  }

  function triggerPuzzleTransition() {
    if(!puzzleLayer || !bottomBg) return;

    const nextIndex = (currentIndex + 1) % images.length;
    bottomBg.style.backgroundImage = `url(${images[nextIndex]})`;

    const tiles = Array.from(puzzleLayer.children) as HTMLElement[];
    const shuffledTiles = [...tiles].sort(() => Math.random() - 0.5);

    shuffledTiles.forEach((tile, i) => {
      setTimeout(() => {
        tile.style.opacity = '0';
      }, i * 30); 
    });

    setTimeout(() => {
      tiles.forEach(tile => {
        tile.style.transition = 'none'; 
        tile.style.backgroundImage = `url(${images[nextIndex]})`;
        tile.style.opacity = '1';
      });
      
      void puzzleLayer.offsetWidth;
      
      tiles.forEach(tile => {
        tile.style.transition = 'opacity 0.4s ease-out';
      });
      
      currentIndex = nextIndex;
    }, (tiles.length * 30) + 500);
  }

  // Initialize and run interval
  initPuzzle();
  setInterval(triggerPuzzleTransition, 5000);

  // 2. Scroll Reveal Logic for the Floating Boxes
  document.addEventListener('DOMContentLoaded', () => {
    const heroBoxes = document.querySelectorAll('.reveal-hero-box');
    
    const heroObserver = new IntersectionObserver((entries, observer) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const index = Array.from(heroBoxes).indexOf(entry.target);
          setTimeout(() => {
            entry.target.classList.add('is-revealed');
          }, index * 150); 
          
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 }); 

    heroBoxes.forEach(box => heroObserver.observe(box));
  });
</script>