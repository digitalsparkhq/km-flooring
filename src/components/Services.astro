---
// src/components/Services.astro
---

<section class="relative py-24 bg-white overflow-hidden" id="services">
  
  <div class="absolute inset-0 z-0 pointer-events-none flex items-center justify-center">
    <svg width="100%" height="100%" preserveAspectRatio="none" viewBox="0 0 1000 1000" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <filter id="waveTexture" x="-20%" y="-20%" width="140%" height="140%">
          <feTurbulence type="fractalNoise" baseFrequency="0.03" numOctaves="3" result="noise" />
          <feDisplacementMap in="SourceGraphic" in2="noise" scale="40" xChannelSelector="R" yChannelSelector="G" />
        </filter>
      </defs>
      <g filter="url(#waveTexture)" opacity="0.08">
        <path d="M -100,250 L 1100,100" fill="none" stroke="#00d2ff" stroke-width="180" stroke-linecap="round" />
        <path d="M -100,800 L 1100,950" fill="none" stroke="#00d2ff" stroke-width="200" stroke-linecap="round" />
        <path d="M 700,-100 L 400,1100" fill="none" stroke="#00d2ff" stroke-width="240" stroke-linecap="round" />
      </g>
    </svg>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-16 reveal-text">
      <h2 class="text-3xl md:text-5xl font-heading font-bold text-brand-navy mb-4">
        Our <span class="text-brand-teal">Services</span>
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto font-sans">
        From full house relocations to single-item pickups, KMS Removals provides affordable, efficient, and reliable services tailored to your exact needs.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      
      <div class="service-card group bg-white rounded-xl border border-gray-100 p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-brand-teal transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        <div class="bg-brand-light w-14 h-14 rounded-lg flex items-center justify-center mb-6 text-brand-teal group-hover:bg-brand-teal group-hover:text-brand-navy transition-colors duration-300">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
        </div>
        <h3 class="font-heading font-bold text-lg text-brand-navy mb-3">Full & Half House Moves</h3>
        <p class="text-sm text-gray-600 leading-relaxed">Complete residential moves using 2-3 man teams. We provide mattress covers, moving sheets, and handle the heavy lifting.</p>
      </div>

      <div class="service-card group bg-white rounded-xl border border-gray-100 p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-brand-teal transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        <div class="bg-brand-light w-14 h-14 rounded-lg flex items-center justify-center mb-6 text-brand-teal group-hover:bg-brand-teal group-hover:text-brand-navy transition-colors duration-300">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" /></svg>
        </div>
        <h3 class="font-heading font-bold text-lg text-brand-navy mb-3">Man with a Van</h3>
        <p class="text-sm text-gray-600 leading-relaxed">Perfect for smaller transport needs, student relocations, or general haulage across the local area.</p>
      </div>

      <div class="service-card group bg-white rounded-xl border border-gray-100 p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-brand-teal transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        <div class="bg-brand-light w-14 h-14 rounded-lg flex items-center justify-center mb-6 text-brand-teal group-hover:bg-brand-teal group-hover:text-brand-navy transition-colors duration-300">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
        </div>
        <h3 class="font-heading font-bold text-lg text-brand-navy mb-3">Home & Office Clearances</h3>
        <p class="text-sm text-gray-600 leading-relaxed">Complete property clear-outs. We will safely remove and responsibly dispose of unwanted items and clutter.</p>
      </div>

      <div class="service-card group bg-white rounded-xl border border-gray-100 p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-brand-teal transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        <div class="bg-brand-light w-14 h-14 rounded-lg flex items-center justify-center mb-6 text-brand-teal group-hover:bg-brand-teal group-hover:text-brand-navy transition-colors duration-300">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
        </div>
        <h3 class="font-heading font-bold text-lg text-brand-navy mb-3">Store Collections</h3>
        <p class="text-sm text-gray-600 leading-relaxed">Bought something big from Wickes, B&Q, or IKEA? We will pick it up and deliver it straight to your door.</p>
      </div>

      <div class="service-card group bg-white rounded-xl border border-gray-100 p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-brand-teal transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        <div class="bg-brand-light w-14 h-14 rounded-lg flex items-center justify-center mb-6 text-brand-teal group-hover:bg-brand-teal group-hover:text-brand-navy transition-colors duration-300">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        </div>
        <h3 class="font-heading font-bold text-lg text-brand-navy mb-3">Dismantling & Assembly</h3>
        <p class="text-sm text-gray-600 leading-relaxed">Don't stress over flat-packs or oversized beds. We offer professional furniture dismantling and reassembly.</p>
      </div>

      <div class="service-card group bg-white rounded-xl border border-gray-100 p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-brand-teal transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        <div class="bg-brand-light w-14 h-14 rounded-lg flex items-center justify-center mb-6 text-brand-teal group-hover:bg-brand-teal group-hover:text-brand-navy transition-colors duration-300">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
        </div>
        <h3 class="font-heading font-bold text-lg text-brand-navy mb-3">Single Item Transport</h3>
        <p class="text-sm text-gray-600 leading-relaxed">Need a sofa, American fridge freezer, or piano moved safely? We provide dedicated single-item transportation.</p>
      </div>

      <div class="service-card group bg-white rounded-xl border border-gray-100 p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-brand-teal transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        <div class="bg-brand-light w-14 h-14 rounded-lg flex items-center justify-center mb-6 text-brand-teal group-hover:bg-brand-teal group-hover:text-brand-navy transition-colors duration-300">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        </div>
        <h3 class="font-heading font-bold text-lg text-brand-navy mb-3">Long Distance Moves</h3>
        <p class="text-sm text-gray-600 leading-relaxed">Moving across the UK? Whether it's short distance or nationwide, we offer reliable, fully insured haulage.</p>
      </div>

      <div class="service-card group bg-white rounded-xl border border-gray-100 p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-brand-teal transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        <div class="bg-brand-light w-14 h-14 rounded-lg flex items-center justify-center mb-6 text-brand-teal group-hover:bg-brand-teal group-hover:text-brand-navy transition-colors duration-300">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
        </div>
        <h3 class="font-heading font-bold text-lg text-brand-navy mb-3">Free Scrap Collection</h3>
        <p class="text-sm text-gray-600 leading-relaxed">Got old appliances, radiators, or scrap metal taking up space? We will take it off your hands entirely for free.</p>
      </div>

    </div>

    <div class="mt-16 text-center reveal-text">
      <button class="quote-trigger bg-brand-teal text-brand-navy px-8 py-3.5 rounded-md hover:bg-brand-navy hover:text-white transition-colors font-heading font-bold shadow-md cursor-pointer inline-flex items-center">
        Get a Free Moving Quote
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </button>
    </div>

  </div>
</section>

<style>
  .reveal-text {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  .service-card {
    opacity: 0;
    transform: translateY(40px) scale(0.95);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .text-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .card-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    box-shadow: 0 10px 15px -3px rgba(10, 10, 60, 0.08), 0 4px 6px -2px rgba(10, 10, 60, 0.04);
  }

  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 25px -5px rgba(10, 10, 60, 0.12), 0 10px 10px -5px rgba(10, 10, 60, 0.06);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          
          if (entry.target.classList.contains('service-card')) {
            const cards = Array.from(entry.target.parentElement?.children || []);
            const index = cards.indexOf(entry.target);
            setTimeout(() => {
              entry.target.classList.add('card-visible');
            }, index * 100); 
          } else if (entry.target.classList.contains('reveal-text')) {
            entry.target.classList.add('text-visible');
          }
          
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    const animatedElements = document.querySelectorAll('.reveal-text, .service-card');
    animatedElements.forEach((el) => observer.observe(el));
  });
</script>