---
// src/components/Services.astro
---

<section class="relative py-24 bg-white overflow-hidden" id="services">
  
  <div class="absolute inset-0 z-0 pointer-events-none flex items-center justify-center opacity-[0.06]">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="parquet-pattern" width="60" height="60" patternUnits="userSpaceOnUse" patternTransform="scale(2)">
          <path d="M0 10 L30 10 M30 0 L30 20 M0 30 L30 30 M30 20 L30 40 M0 50 L30 50 M30 40 L30 60" fill="none" stroke="#A66D42" stroke-width="1" />
          <path d="M30 10 L60 10 M60 0 L60 20 M30 30 L60 30 M60 20 L60 40 M30 50 L60 50 M60 40 L60 60" fill="none" stroke="#A66D42" stroke-width="1" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#parquet-pattern)" />
    </svg>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-16 reveal-text">
      <h2 class="text-3xl md:text-5xl font-heading font-black text-brand-navy mb-4 uppercase tracking-tight bg-white inline-block px-4 py-2 rounded-lg shadow-sm border border-slate-100">
        Premium Flooring <span class="text-brand-teal">Services</span>
      </h2>
      <p class="text-lg text-gray-700 max-w-2xl mx-auto font-sans font-medium mt-4 bg-white/80 backdrop-blur-sm p-4 rounded-xl shadow-sm border border-white/50">
        From stunning herringbone LVT to durable safety flooring, we supply and fit high-quality flooring with a flawless finish across Hull and East Yorkshire.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      
      <div class="service-card group bg-white rounded-xl border border-gray-100 p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-brand-teal transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        <div class="bg-slate-50 w-14 h-14 rounded-lg flex items-center justify-center mb-6 text-brand-teal group-hover:bg-brand-teal group-hover:text-white transition-colors duration-300 shadow-sm border border-slate-100">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
        </div>
        <h3 class="font-heading font-black text-lg text-brand-navy mb-3 uppercase tracking-wide">Herringbone LVT</h3>
        <p class="text-sm text-gray-600 leading-relaxed font-medium">Expertly laid classic herringbone patterns that add character, movement, and a high-end feel to any room in your home.</p>
      </div>

      <div class="service-card group bg-white rounded-xl border border-gray-100 p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-brand-teal transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        <div class="bg-slate-50 w-14 h-14 rounded-lg flex items-center justify-center mb-6 text-brand-teal group-hover:bg-brand-teal group-hover:text-white transition-colors duration-300 shadow-sm border border-slate-100">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </div>
        <h3 class="font-heading font-black text-lg text-brand-navy mb-3 uppercase tracking-wide">Straight Plank LVT</h3>
        <p class="text-sm text-gray-600 leading-relaxed font-medium">Clean, modern, and cohesive. We install premium planks that offer the authentic look of real wood with unbeatable water-resistant durability.</p>
      </div>

      <div class="service-card group bg-white rounded-xl border border-gray-100 p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-brand-teal transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        <div class="bg-slate-50 w-14 h-14 rounded-lg flex items-center justify-center mb-6 text-brand-teal group-hover:bg-brand-teal group-hover:text-white transition-colors duration-300 shadow-sm border border-slate-100">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4h16v16H4V4zm4 4h8v8H8V8z"></path></svg>
        </div>
        <h3 class="font-heading font-black text-lg text-brand-navy mb-3 uppercase tracking-wide">Custom Borders</h3>
        <p class="text-sm text-gray-600 leading-relaxed font-medium">Elevate your design with precise detailing. We create sharp, well-defined layouts using contrast feature strips and double plank borders.</p>
      </div>

      <div class="service-card group bg-white rounded-xl border border-gray-100 p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-brand-teal transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        <div class="bg-slate-50 w-14 h-14 rounded-lg flex items-center justify-center mb-6 text-brand-teal group-hover:bg-brand-teal group-hover:text-white transition-colors duration-300 shadow-sm border border-slate-100">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
        </div>
        <h3 class="font-heading font-black text-lg text-brand-navy mb-3 uppercase tracking-wide">Safety Flooring</h3>
        <p class="text-sm text-gray-600 leading-relaxed font-medium">Slip-resistant, highly durable flooring solutions perfect for wet rooms, bathrooms, and demanding commercial environments.</p>
      </div>

      <div class="service-card group bg-white rounded-xl border border-gray-100 p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-brand-teal transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        <div class="bg-slate-50 w-14 h-14 rounded-lg flex items-center justify-center mb-6 text-brand-teal group-hover:bg-brand-teal group-hover:text-white transition-colors duration-300 shadow-sm border border-slate-100">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
        </div>
        <h3 class="font-heading font-black text-lg text-brand-navy mb-3 uppercase tracking-wide">Subfloor Preparation</h3>
        <p class="text-sm text-gray-600 leading-relaxed font-medium">A flawless finish requires a perfect base. We handle all screeding, boarding, and levelling to ensure your new floor lasts a lifetime.</p>
      </div>

      <div class="service-card group bg-white rounded-xl border border-gray-100 p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-brand-teal transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        <div class="bg-slate-50 w-14 h-14 rounded-lg flex items-center justify-center mb-6 text-brand-teal group-hover:bg-brand-teal group-hover:text-white transition-colors duration-300 shadow-sm border border-slate-100">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        </div>
        <h3 class="font-heading font-black text-lg text-brand-navy mb-3 uppercase tracking-wide">Full Supply & Fit</h3>
        <p class="text-sm text-gray-600 leading-relaxed font-medium">From sourcing top brands like Textures and Symphony LVT to expert installation, we provide a stress-free, end-to-end service.</p>
      </div>

    </div>

    <div class="mt-16 text-center reveal-text">
      <a href="/contact" class="bg-brand-teal text-white px-8 py-4 rounded-md hover:bg-brand-navy transition-colors font-heading font-black tracking-wide shadow-md inline-flex items-center">
        Book a Free Measure & Quote
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
    </div>

  </div>
</section>

<style>
  .reveal-text {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  .service-card {
    opacity: 0;
    transform: translateY(40px) scale(0.95);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .text-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .card-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    box-shadow: 0 10px 15px -3px rgba(15, 23, 42, 0.08), 0 4px 6px -2px rgba(15, 23, 42, 0.04);
  }

  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 25px -5px rgba(15, 23, 42, 0.12), 0 10px 10px -5px rgba(15, 23, 42, 0.06);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          
          if (entry.target.classList.contains('service-card')) {
            const cards = Array.from(entry.target.parentElement?.children || []);
            const index = cards.indexOf(entry.target);
            setTimeout(() => {
              entry.target.classList.add('card-visible');
            }, index * 100); 
          } else if (entry.target.classList.contains('reveal-text')) {
            entry.target.classList.add('text-visible');
          }
          
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    const animatedElements = document.querySelectorAll('.reveal-text, .service-card');
    animatedElements.forEach((el) => observer.observe(el));
  });
</script>