---
// src/components/RecentWork.astro

const projects = [
  {
    title: "Kardean Van Gogh LVT - Warm Brushed Oak",
    img: "/images/floor1.jpg",
  },
  {
    title: "Blonde Oak - Camero LVT",
    img: "/images/floor2.jpg",
  },
  {
    title: "Aspire LVT - Classical Oak",
    img: "/images/floor3.jpg",
  },
  {
    title: "Camaro - Cashmere Oak",
    img: "/images/floor4.jpg",
  },
  {
    title: "Symphony LVT - Forest Oak",
    img: "/images/floor5.jpg",
  },
  {
    title: "Washed Oak - Textures LVT",
    img: "/images/floor6.jpg",
  },
  {
    title: "Tromso LVT - Slate Grey",
    img: "/images/floor7.jpg",
  },
  {
    title: "Old English Oak - Textures LVT",
    img: "/images/floor8.jpg",
  },
  {
    title: "Aspire Parquet - Classic Oak",
    img: "/images/floor9.jpg",
  }
];
---

<section class="py-24 bg-white overflow-hidden" id="our-work">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="text-center mb-16 reveal-on-scroll">
      <span class="text-brand-teal font-bold tracking-widest uppercase text-sm mb-3 block">Our Portfolio</span>
      <h2 class="text-3xl md:text-5xl font-heading font-black text-brand-navy mb-4 uppercase tracking-tight">
        Recent <span class="text-brand-teal">Installations</span>
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto font-sans font-medium leading-relaxed">
        Take a look at some of our latest premium LVT installations. From stunning herringbone patterns to clean straight planks, we pride ourselves on delivering a flawless finish every time.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((project) => (
        <div class="group flex flex-col items-center reveal-on-scroll">
          
          <div class="gallery-trigger relative w-full aspect-[4/3] flex rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 cursor-pointer"
               data-title={project.title}
               data-img={project.img}>
            
            <div class="absolute inset-0 bg-brand-navy/0 group-hover:bg-brand-navy/40 z-20 transition-colors duration-300 flex items-center justify-center pointer-events-none">
                <svg class="w-12 h-12 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 drop-shadow-lg transform scale-50 group-hover:scale-100" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" /></svg>
            </div>

            <img src={project.img} alt={project.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
          </div>
          
          <h3 class="text-sm md:text-base font-heading font-bold text-brand-navy mt-5 text-center px-2">{project.title}</h3>
        </div>
      ))}
    </div>

    <div class="mt-16 text-center reveal-on-scroll">
      <a href="/contact" class="inline-flex justify-center items-center px-8 py-4 border border-transparent text-lg font-black uppercase tracking-wider rounded-md text-white bg-brand-navy hover:bg-brand-teal transition-colors shadow-lg shadow-brand-navy/20">
        Book Your Installation
      </a>
    </div>

  </div>
</section>

<div id="lightbox" class="fixed inset-0 z-[100] hidden flex-col items-center justify-center p-4 sm:p-8 opacity-0 transition-opacity duration-300" aria-modal="true" role="dialog">
  
  <div id="lightbox-backdrop" class="absolute inset-0 bg-brand-navy/95 backdrop-blur-md cursor-pointer transition-opacity"></div>
  
  <button type="button" id="lightbox-close" class="absolute top-6 right-6 sm:top-8 sm:right-8 text-white/70 hover:text-brand-teal focus:outline-none z-50 cursor-pointer bg-brand-navy/50 hover:bg-brand-navy p-2 rounded-full transition-all">
    <span class="sr-only">Close image</span>
    <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
  </button>

  <div class="relative z-10 w-full max-w-5xl flex flex-col items-center transform scale-95 transition-transform duration-300" id="lightbox-content">
    <h3 id="lightbox-title" class="text-xl md:text-3xl font-heading font-bold text-white mb-6 text-center drop-shadow-md px-4"></h3>
    
    <div class="relative w-full max-w-4xl flex justify-center">
      <img id="lightbox-single-img" src="" alt="Full Work View" class="max-h-[75vh] w-auto object-contain rounded-xl shadow-2xl border border-white/10" />
    </div>
  </div>
</div>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(40px) scale(0.95);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .is-revealed {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  
  .img-loaded {
    transform: scale(1) !important;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    
    // Scroll Reveal Animation
    const revealOptions = { root: null, rootMargin: '0px', threshold: 0.1 };
    const revealObserver = new IntersectionObserver((entries, observer) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          observer.unobserve(entry.target);
        }
      });
    }, revealOptions);

    document.querySelectorAll('.reveal-on-scroll').forEach(el => revealObserver.observe(el));

    // Lightbox Logic
    const triggers = document.querySelectorAll('.gallery-trigger');
    const lightbox = document.getElementById('lightbox');
    const closeBtn = document.getElementById('lightbox-close');
    const backdrop = document.getElementById('lightbox-backdrop');
    
    const lbTitle = document.getElementById('lightbox-title');
    const lbContent = document.getElementById('lightbox-content');
    const lbSingleImg = document.getElementById('lightbox-single-img');

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        if(lbTitle && lightbox && lbContent && lbSingleImg) {
            
            // Set data
            lbTitle.textContent = trigger.getAttribute('data-title');
            lbSingleImg.setAttribute('src', trigger.getAttribute('data-img') || '');
            
            // Show lightbox
            lightbox.classList.remove('hidden');
            lightbox.classList.add('flex');
            document.body.style.overflow = 'hidden';
            
            // Animate in
            setTimeout(() => {
              lightbox.classList.remove('opacity-0');
              lbContent.classList.add('img-loaded');
            }, 50);
        }
      });
    });

    const closeLightbox = () => {
      if(lightbox && lbContent) {
          lightbox.classList.add('opacity-0');
          lbContent.classList.remove('img-loaded');
          setTimeout(() => {
            lightbox.classList.add('hidden');
            lightbox.classList.remove('flex');
            document.body.style.overflow = 'auto';
            
            // Clean up source so old image doesn't flash on next open
            if (lbSingleImg) lbSingleImg.setAttribute('src', '');
          }, 300); 
      }
    };

    if(closeBtn) closeBtn.addEventListener('click', closeLightbox);
    if(backdrop) backdrop.addEventListener('click', closeLightbox);
    
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox && !lightbox.classList.contains('hidden')) {
        closeLightbox();
      }
    });
  });
</script>