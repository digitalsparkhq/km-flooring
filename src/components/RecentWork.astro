---
// src/components/RecentWork.astro

const splitProjects = [
  {
    title: "Full House Clearance",
    beforeImg: "/images/work-before1.jpg", 
    afterImg: "/images/work-after1.jpg",
  },
  {
    title: "Dismantling & Assembly",
    beforeImg: "/images/work-before2.jpg",
    afterImg: "/images/work-after2.jpg",
  }
];

const singleProjects = [
  {
    title: "Careful Loading",
    img: "/images/work1.jpg",
  },
  {
    title: "Fully Equipped Vans",
    img: "/images/work2.jpg",
  },
  {
    title: "Safe Transport",
    img: "/images/work3.jpg",
  }
];
---

<section class="py-24 bg-white overflow-hidden" id="our-work">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="text-center mb-16 reveal-on-scroll">
      <h2 class="text-3xl md:text-5xl font-heading font-bold text-brand-navy mb-4">
        Our Recent <span class="text-brand-teal">Work</span>
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto font-sans">
        Take a look at some of our latest house moves and commercial clearances. The team takes pride in ensuring your belongings are transported safely and your spaces are left spotless.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-10">
      {splitProjects.map((project) => (
        <div class="group flex flex-col items-center reveal-on-scroll">
          
          <div class="gallery-trigger relative w-full aspect-[4/3] flex rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 cursor-pointer"
               data-type="split"
               data-title={project.title}
               data-before={project.beforeImg}
               data-after={project.afterImg}>
            
            <div class="absolute inset-0 bg-brand-navy/0 group-hover:bg-brand-navy/30 z-20 transition-colors duration-300 flex items-center justify-center pointer-events-none">
                <svg class="w-12 h-12 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 drop-shadow-lg transform scale-50 group-hover:scale-100" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" /></svg>
            </div>

            <div class="w-1/2 relative h-full overflow-hidden">
              <img src={project.beforeImg} alt="Before" class="w-full h-full object-cover grayscale-[20%] brightness-75 transition-transform duration-700 group-hover:scale-105" />
              <div class="absolute top-3 left-3 bg-brand-navy/90 backdrop-blur text-white text-xs font-bold px-2 py-1 rounded uppercase tracking-wider">Before</div>
            </div>

            <div class="absolute inset-y-0 left-1/2 w-1 bg-brand-teal z-10 transform -translate-x-1/2 shadow-[0_0_10px_rgba(0,210,255,0.5)]"></div>

            <div class="w-1/2 relative h-full overflow-hidden">
              <img src={project.afterImg} alt="After" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
              <div class="absolute top-3 right-3 bg-brand-teal text-brand-navy text-xs font-bold px-2 py-1 rounded uppercase tracking-wider shadow-sm">After</div>
            </div>

          </div>
          <h3 class="text-xl font-heading font-bold text-brand-navy mt-6 text-center">{project.title}</h3>
        </div>
      ))}
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
      {singleProjects.map((project) => (
        <div class="group flex flex-col items-center reveal-on-scroll">
          
          <div class="gallery-trigger relative w-full aspect-[4/3] flex rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 cursor-pointer"
               data-type="single"
               data-title={project.title}
               data-img={project.img}>
            
            <div class="absolute inset-0 bg-brand-navy/0 group-hover:bg-brand-navy/30 z-20 transition-colors duration-300 flex items-center justify-center pointer-events-none">
                <svg class="w-12 h-12 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 drop-shadow-lg transform scale-50 group-hover:scale-100" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" /></svg>
            </div>

            <img src={project.img} alt={project.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
          </div>
          <h3 class="text-lg font-heading font-bold text-brand-navy mt-4 text-center">{project.title}</h3>
        </div>
      ))}
    </div>

    <div class="mt-16 text-center reveal-on-scroll">
      <button class="quote-trigger inline-flex justify-center items-center px-8 py-3.5 border-2 border-brand-teal text-base font-bold rounded-md text-brand-navy hover:bg-brand-teal hover:text-white transition-colors font-heading cursor-pointer">
        Book Your Move Today
      </button>
    </div>

  </div>
</section>

<div id="lightbox" class="fixed inset-0 z-[100] hidden flex-col items-center justify-center p-4 sm:p-8 opacity-0 transition-opacity duration-300" aria-modal="true" role="dialog">
  
  <div id="lightbox-backdrop" class="absolute inset-0 bg-brand-navy/95 backdrop-blur-md cursor-pointer transition-opacity"></div>
  
  <button type="button" id="lightbox-close" class="absolute top-6 right-6 sm:top-8 sm:right-8 text-white/70 hover:text-brand-teal focus:outline-none z-50 cursor-pointer bg-brand-navy/50 hover:bg-brand-navy p-2 rounded-full transition-all">
    <span class="sr-only">Close image</span>
    <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
  </button>

  <div class="relative z-10 w-full max-w-5xl flex flex-col items-center transform scale-95 transition-transform duration-300" id="lightbox-content">
    <h3 id="lightbox-title" class="text-2xl md:text-4xl font-heading font-bold text-white mb-8 text-center drop-shadow-md"></h3>
    
    <div id="lightbox-split-view" class="relative w-full aspect-[4/3] md:aspect-[16/9] flex rounded-xl overflow-hidden shadow-2xl border border-white/10 hidden">
      <div class="w-1/2 relative h-full">
        <img id="lightbox-before" src="" alt="Full Before View" class="w-full h-full object-cover grayscale-[15%] brightness-[0.85]" />
        <div class="absolute top-4 left-4 md:top-6 md:left-6 bg-brand-navy/90 text-white text-sm md:text-lg font-bold px-4 py-2 rounded uppercase tracking-wider">Before</div>
      </div>
      
      <div class="absolute inset-y-0 left-1/2 w-1.5 md:w-2 bg-brand-teal z-10 transform -translate-x-1/2 shadow-[0_0_20px_rgba(0,210,255,0.6)]"></div>
      
      <div class="w-1/2 relative h-full">
        <img id="lightbox-after" src="" alt="Full After View" class="w-full h-full object-cover" />
        <div class="absolute top-4 right-4 md:top-6 md:right-6 bg-brand-teal text-brand-navy text-sm md:text-lg font-bold px-4 py-2 rounded uppercase tracking-wider shadow-lg">After</div>
      </div>
    </div>

    <div id="lightbox-single-view" class="relative w-full max-w-4xl flex justify-center hidden">
      <img id="lightbox-single-img" src="" alt="Full Work View" class="max-h-[75vh] w-auto object-contain rounded-xl shadow-2xl border border-white/10" />
    </div>

  </div>
</div>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(40px) scale(0.95);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .is-revealed {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  
  .img-loaded {
    transform: scale(1) !important;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    
    // Scroll Reveal Animation
    const revealOptions = { root: null, rootMargin: '0px', threshold: 0.1 };
    const revealObserver = new IntersectionObserver((entries, observer) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          observer.unobserve(entry.target);
        }
      });
    }, revealOptions);

    document.querySelectorAll('.reveal-on-scroll').forEach(el => revealObserver.observe(el));

    // Smart Lightbox Logic
    const triggers = document.querySelectorAll('.gallery-trigger');
    const lightbox = document.getElementById('lightbox');
    const closeBtn = document.getElementById('lightbox-close');
    const backdrop = document.getElementById('lightbox-backdrop');
    
    const lbTitle = document.getElementById('lightbox-title');
    const lbContent = document.getElementById('lightbox-content');
    
    const splitViewContainer = document.getElementById('lightbox-split-view');
    const lbBefore = document.getElementById('lightbox-before');
    const lbAfter = document.getElementById('lightbox-after');
    
    const singleViewContainer = document.getElementById('lightbox-single-view');
    const lbSingleImg = document.getElementById('lightbox-single-img');

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        if(lbTitle && lightbox && lbContent && splitViewContainer && singleViewContainer) {
            
            const type = trigger.getAttribute('data-type');
            lbTitle.textContent = trigger.getAttribute('data-title');
            
            if (type === 'split') {
              // Handle Before & After View
              if (lbBefore) lbBefore.setAttribute('src', trigger.getAttribute('data-before') || '');
              if (lbAfter) lbAfter.setAttribute('src', trigger.getAttribute('data-after') || '');
              
              splitViewContainer.classList.remove('hidden');
              singleViewContainer.classList.add('hidden');
            } else {
              // Handle Single Image View
              if (lbSingleImg) lbSingleImg.setAttribute('src', trigger.getAttribute('data-img') || '');
              
              singleViewContainer.classList.remove('hidden');
              splitViewContainer.classList.add('hidden');
            }
            
            lightbox.classList.remove('hidden');
            lightbox.classList.add('flex');
            document.body.style.overflow = 'hidden';
            
            setTimeout(() => {
              lightbox.classList.remove('opacity-0');
              lbContent.classList.add('img-loaded');
            }, 50);
        }
      });
    });

    const closeLightbox = () => {
      if(lightbox && lbContent) {
          lightbox.classList.add('opacity-0');
          lbContent.classList.remove('img-loaded');
          setTimeout(() => {
            lightbox.classList.add('hidden');
            lightbox.classList.remove('flex');
            document.body.style.overflow = 'auto';
            
            // Clean up sources so old images don't flash on next open
            if (lbBefore) lbBefore.setAttribute('src', '');
            if (lbAfter) lbAfter.setAttribute('src', '');
            if (lbSingleImg) lbSingleImg.setAttribute('src', '');
          }, 300); 
      }
    };

    if(closeBtn) closeBtn.addEventListener('click', closeLightbox);
    if(backdrop) backdrop.addEventListener('click', closeLightbox);
    
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox && !lightbox.classList.contains('hidden')) {
        closeLightbox();
      }
    });
  });
</script>