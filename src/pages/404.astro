---
// src/pages/404.astro
import Layout from '../layouts/layout.astro';
---

<Layout 
  title="Page Not Found | KM Flooring"
  description="Oops! It looks like this page doesn't exist. Let's get you back to solid ground."
>
  <section class="relative min-h-[70vh] flex items-center justify-center bg-white overflow-hidden py-24 px-6">
    
    <div class="absolute inset-0 z-0 pointer-events-none flex items-center justify-center opacity-60">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="parquet-404" width="60" height="60" patternUnits="userSpaceOnUse" patternTransform="scale(3)">
            <path d="M0 10 L30 10 M30 0 L30 20 M0 30 L30 30 M30 20 L30 40 M0 50 L30 50 M30 40 L30 60" fill="none" stroke="#f1f5f9" stroke-width="1" />
            <path d="M30 10 L60 10 M60 0 L60 20 M30 30 L60 30 M60 20 L60 40 M30 50 L60 50 M60 40 L60 60" fill="none" stroke="#f1f5f9" stroke-width="1" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#parquet-404)" />
      </svg>
    </div>

    <div class="relative z-10 text-center max-w-2xl mx-auto">
      
      <h1 class="text-8xl md:text-9xl font-heading font-black text-brand-navy drop-shadow-sm mb-4">
        4<span class="text-brand-teal">0</span>4
      </h1>
      
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-navy mb-6 uppercase tracking-wide">
        Oops! We haven't laid <br class="hidden sm:block"/> this floor yet.
      </h2>
      
      <p class="text-lg md:text-xl text-gray-600 font-medium mb-12">
        The page you are looking for might have been removed, had its name changed, or is temporarily unavailable. Let's get you back to solid ground.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="/" class="inline-flex justify-center items-center px-8 py-4 border border-transparent text-lg font-black uppercase tracking-wider rounded-md text-white bg-brand-navy hover:bg-brand-teal transition-colors shadow-lg w-full sm:w-auto">
          Back to Homepage
        </a>
        <a href="/#services" class="inline-flex justify-center items-center px-8 py-4 border-2 border-brand-teal text-lg font-black uppercase tracking-wider rounded-md text-brand-navy hover:bg-brand-teal hover:text-white transition-colors bg-white w-full sm:w-auto">
          View Our Services
        </a>
      </div>

    </div>
  </section>
</Layout>