---
import Layout from '../layouts/layout.astro';

const contactHeroImage = "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?q=80&w=2940&auto=format&fit=crop";
---

<Layout 
  title="Contact KMS Removals | Get a Free Moving Quote"
  description="Need reliable removals in Doncaster or across the UK? Contact KMS Removals for a free, no-obligation quote on house moves, clearances, and single item transport."
>
  
  <section class="relative w-full h-[500px] md:h-[600px] lg:h-[700px] min-h-[500px] flex items-center justify-center overflow-hidden border-b-8 border-brand-teal pb-12 md:pb-20">
    
    <div class="absolute inset-0 z-0">
      <img 
        src={contactHeroImage} 
        alt="Contact KMS Removals" 
        class="absolute inset-0 w-full h-full object-cover min-w-full min-h-full"
      />
      <div class="absolute inset-0 bg-brand-navy/80 z-10"></div>
    </div>

    <div class="relative z-20 text-center px-6 max-w-4xl mx-auto">
      <span class="text-brand-teal font-bold tracking-widest uppercase text-sm md:text-base mb-4 block">Get In Touch</span>
      <h1 class="text-5xl md:text-7xl font-black uppercase text-white mb-6 drop-shadow-2xl">
        Contact <span class="text-brand-teal">KMS</span>
      </h1>
      <p class="text-xl md:text-2xl text-white font-bold leading-relaxed drop-shadow-lg">
        Ready to move, clear, or transport? We're here to do the heavy lifting for you.
      </p>
    </div>

  </section>

  <section class="py-24 bg-white px-6 relative z-10">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row gap-12 lg:gap-16 items-start">
      
      <div class="w-full md:w-5/12 lg:w-4/12 flex flex-col gap-8 order-1">
        
        <div class="bg-slate-50 border-2 border-slate-100 rounded-3xl p-8 space-y-6 shadow-xl">
          
          <div class="flex gap-4">
            <div class="text-brand-teal flex-shrink-0">
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /></svg>
            </div>
            <div>
              <h4 class="font-black text-brand-navy uppercase tracking-wide mb-1">Our Base Location</h4>
              <p class="text-gray-600 font-bold leading-tight">Doncaster, United Kingdom<br/><span class="text-sm font-medium text-brand-teal">Covering all of the UK</span></p>
            </div>
          </div>
          
          <div class="flex gap-4 border-t border-slate-200 pt-6">
            <div class="text-brand-teal flex-shrink-0">
               <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            </div>
            <div>
              <h4 class="font-black text-brand-navy uppercase tracking-wide mb-1 text-sm">Call Direct</h4>
              <a href="tel:07395936013" class="text-gray-600 font-bold hover:text-brand-teal transition-colors">07395 936013</a>
            </div>
          </div>

          <div class="flex gap-4 border-t border-slate-200 pt-6">
            <div class="text-brand-teal flex-shrink-0">
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <div>
              <h4 class="font-black text-brand-navy uppercase tracking-wide mb-1 text-sm">Email Address</h4>
              <a href="mailto:kmsremovals@myyahoo.com" class="text-gray-600 font-bold hover:text-brand-teal transition-colors break-all">kmsremovals@myyahoo.com</a>
            </div>
          </div>
        </div>

        <div class="h-64 bg-slate-100 rounded-3xl overflow-hidden border-2 border-brand-navy shadow-lg">
           <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d75960.91683416413!2d-1.1966551827447814!3d53.52282035848777!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x48790c885bb34493%3A0x7422f2f761d7b69c!2sDoncaster!5e0!3m2!1sen!2suk!4v1714421453211!5m2!1sen!2suk" class="w-full h-full border-0 grayscale hover:grayscale-0 transition-all duration-700" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>

      <div class="w-full md:w-7/12 lg:w-[60%] bg-slate-50 border-2 border-slate-100 p-8 md:p-12 rounded-[2.5rem] shadow-2xl order-2">
        <h2 class="text-3xl font-black text-brand-navy mb-2 uppercase italic">Request a Quote</h2>
        <p class="text-gray-600 mb-8 font-medium border-l-4 border-brand-teal pl-4">Tell us what you need moving and we'll reply instantly on WhatsApp.</p>
        
        <form id="contact-whatsapp-form" class="space-y-6">
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <input id="contact-name" type="text" placeholder="FULL NAME *" required class="bg-white border-2 border-slate-200 rounded-xl px-4 py-4 focus:outline-none focus:border-brand-teal font-bold shadow-sm" />
            <input id="contact-phone" type="tel" placeholder="PHONE NUMBER *" required class="bg-white border-2 border-slate-200 rounded-xl px-4 py-4 focus:outline-none focus:border-brand-teal font-bold shadow-sm" />
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <input id="contact-pickup" type="text" placeholder="PICKUP POSTCODE *" required class="bg-white border-2 border-slate-200 rounded-xl px-4 py-4 focus:outline-none focus:border-brand-teal uppercase font-black shadow-sm" />
            <input id="contact-dropoff" type="text" placeholder="DROPOFF POSTCODE" class="bg-white border-2 border-slate-200 rounded-xl px-4 py-4 focus:outline-none focus:border-brand-teal uppercase font-black shadow-sm" />
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <select id="contact-service" required class="bg-white border-2 border-slate-200 rounded-xl px-4 py-4 focus:outline-none focus:border-brand-teal font-bold cursor-pointer shadow-sm">
              <option value="" disabled selected>SERVICE TYPE *</option>
              <option value="Full House Move">Full House Move</option>
              <option value="Half House Move">Half House Move</option>
              <option value="Single/Large Item Collection">Single/Large Item Collection</option>
              <option value="Store Pickup (B&Q, Wickes, etc.)">Store Pickup (B&Q, Wickes, etc.)</option>
              <option value="Home/Office Clearance">Home/Office Clearance</option>
              <option value="Scrap Metal Collection">Scrap Metal Collection</option>
            </select>
            
            <select id="contact-timescale" required class="bg-white border-2 border-slate-200 rounded-xl px-4 py-4 focus:outline-none focus:border-brand-teal font-bold cursor-pointer shadow-sm">
              <option value="" disabled selected>TIMESCALE *</option>
              <option value="ASAP (Urgent)">ASAP (Urgent)</option>
              <option value="Within 3 Days">Within 3 Days</option>
              <option value="Within 1 Week">Within 1 Week</option>
              <option value="Flexible">Flexible</option>
            </select>
          </div>

          <textarea id="contact-desc" rows="4" placeholder="DESCRIBE THE ITEMS TO BE MOVED..." required class="bg-white border-2 border-slate-200 rounded-xl px-4 py-4 focus:outline-none focus:border-brand-teal font-bold w-full shadow-sm"></textarea>
          
          <button type="submit" class="w-full cursor-pointer bg-[#25D366] text-white flex items-center justify-center gap-3 text-xl md:text-2xl font-black uppercase tracking-widest py-5 rounded-xl shadow-[0_8px_0_0_#128C7E] active:shadow-none active:translate-y-2 transition-all hover:bg-[#20ba59]">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 fill-current" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 000 12a12 12 0 001.602 6.001L0 24l6.19-1.604A12 12 0 0012.056 24 12 12 0 0024 12c0-6.627-5.373-12-12.056-12zM12.056 22A10 10 0 015.353 20.32l-.382-.226-4.008 1.037 1.056-3.905-.248-.395A10 10 0 1112.056 22zm5.558-7.512c-.305-.152-1.804-.891-2.083-.993-.279-.102-.482-.152-.686.152-.203.305-.788.993-.966 1.197-.178.203-.356.228-.661.076-.305-.152-1.287-.475-2.453-1.516-.906-.81-1.517-1.809-1.696-2.114-.178-.305-.019-.469.133-.62.138-.138.305-.356.458-.534.152-.178.203-.305.305-.508.102-.203.051-.381-.025-.534-.076-.152-.686-1.652-.94-2.261-.247-.591-.497-.512-.686-.521-.178-.009-.381-.009-.584-.009-.203 0-.534.076-.813.381-.279.305-1.067 1.042-1.067 2.54 0 1.498 1.093 2.946 1.246 3.149.152.203 2.147 3.275 5.2 4.59.725.313 1.291.5 1.733.64.728.232 1.391.199 1.914.12.585-.088 1.804-.737 2.058-1.448.254-.711.254-1.32.178-1.448-.076-.127-.28-.203-.585-.356z"/></svg>
            Send via WhatsApp
          </button>
        </form>
      </div>

    </div>
  </section>

</Layout>

<script is:inline>
  const contactForm = document.getElementById('contact-whatsapp-form');

  contactForm?.addEventListener('submit', (e) => {
    e.preventDefault(); 

    const name = document.getElementById('contact-name')?.value || '';
    const phone = document.getElementById('contact-phone')?.value || '';
    const pickup = document.getElementById('contact-pickup')?.value || '';
    const dropoff = document.getElementById('contact-dropoff')?.value || 'N/A';
    const service = document.getElementById('contact-service')?.value || '';
    const timescale = document.getElementById('contact-timescale')?.value || '';
    const desc = document.getElementById('contact-desc')?.value || '';

    const rawMessage = `*Website Quote Request (KMS Removals)*\n\n` +
                       `*Name:* ${name}\n` +
                       `*Phone:* ${phone}\n\n` +
                       `*Service Required:* ${service}\n` +
                       `*Timescale:* ${timescale}\n\n` +
                       `*📍 Pickup Postcode:* ${pickup}\n` +
                       `*📍 Drop-off Postcode:* ${dropoff}\n\n` +
                       `*Items Description:*\n${desc}`;

    const encodedMessage = encodeURIComponent(rawMessage);
    const whatsappNumber = "447395936013";
    
    const whatsappURL = `https://wa.me/${whatsappNumber}?text=${encodedMessage}`;
    window.open(whatsappURL, '_blank');

    contactForm.reset();
  });
</script>